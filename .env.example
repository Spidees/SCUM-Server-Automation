# Copy this file to .env and fill in real values. Never commit .env to git.

# Discord bot token - if set, the Discord bot starts automatically.
# Configure channel/role IDs in config/config.json under "Discord".
DISCORD_TOKEN=

# Web panel
WEB_ADMIN_PASSWORD=changeme
SESSION_SECRET=changeme

# "Login with Discord" for the public player area (optional). Create an OAuth2
# app in the Discord Developer Portal, add the redirect URI below to it, and copy
# the Client ID / Client Secret here. Leave blank to disable Discord login.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered in the Discord app, e.g.
# https://your-domain/api/auth/discord/callback
DISCORD_OAUTH_REDIRECT=
